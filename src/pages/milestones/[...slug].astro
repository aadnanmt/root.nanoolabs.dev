---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import BackToPrev from "@components/BackToPrev.astro";

export async function getStaticPaths() {
  const milestones = await getCollection("milestones");
  return milestones.map((milestone) => ({
    params: { slug: milestone.slug },
    props: milestone,
  }));
}
type Props = CollectionEntry<"milestones">;

const milestone = Astro.props;
const { Content } = await milestone.render();

const moodColor = {
  Good: "text-green-500",
  Neutral: "text-yellow-500",
  Bad: "text-red-500",
}[milestone.data.mood || "Neutral"];

const moodEmoji = {
  Good: "😊",
  Neutral: "😐",
  Bad: "😔",
  Tired: "😴",
  SoHappy: "😁",
  SoBad: "😿",
}[milestone.data.mood || "Neutral"];
---

<PageLayout
  title={milestone.data.title}
  description={milestone.data.lessonLearn || milestone.body}
>
  <Container>
    <div class="animate">
      <BackToPrev href="/milestones"> Back to milestones </BackToPrev>
    </div>
    <div class="my-10 space-y-1">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={milestone.data.date} />
        </div>
        {
          milestone.data.mood && (
            <>
              &bull;
              <div class="font-base text-sm">
                Mood:{" "}
                <span class={`${moodColor} font-semibold`}>
                  {milestone.data.mood} {moodEmoji}
                </span>
              </div>
            </>
          )
        }
      </div>
      <div class="animate text-3xl font-semibold text-black dark:text-white">
        {milestone.data.title}
      </div>
      {
        milestone.data.lessonLearn && (
          <p class="animate mt-2 text-sm italic opacity-70">
            Lesson Learned: "{milestone.data.lessonLearn}"
          </p>
        )
      }
    </div>
    <article class="animate prose prose-neutral max-w-none dark:prose-invert">
      <Content />
    </article>
  </Container>
</PageLayout>
