---
import PageLayout from "@layouts/PageLayout.astro"
import Container from "@components/Container.astro"
import Link from "@components/Link.astro"
import TimeStatus from "@components/TimeStatus.astro"
import { SITE, SOCIALS } from "@consts"
import {
  IconEmail,
  IconGithub,
  IconX,
  IconTelegram,
  IconInstagram,
  IconKofi,
  IconGitlab,
} from "@lib/iconSystem"

const getIcon = (name: string) => {
  switch (name.toLowerCase()) {
    case "github":
      return IconGithub
    case "x-twitter":
      return IconX
    case "telegram":
      return IconTelegram
    case "instagram":
      return IconInstagram
    case "ko-fi":
      return IconKofi
    case "gitlab":
      return IconGitlab
    default:
      return IconEmail
  }
}
---

<PageLayout title="Contact" description={`Get in touch with ${SITE.NAME}`}>
  <Container>
    <div class="animate space-y-10">
      <div class="animate">
        <TimeStatus />
      </div>

      <div class="space-y-12">
        <section class="animate space-y-4">
          <h4 class="font-semibold text-black dark:text-white">
            Professional Inquiries
          </h4>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">
            For collaboration, project proposals, or deep technical discussions,
            email is the most reliable way to reach me.
          </p>
          <div class="flex items-center gap-2">
            <div class="size-4 fill-zinc-500">
              <Fragment set:html={IconEmail} />
            </div>
            <Link href={`mailto:${SITE.EMAIL}`} external>
              {SITE.EMAIL}
            </Link>
          </div>
        </section>

        <section class="animate space-y-6">
          <h4 class="font-semibold text-black dark:text-white">
            Social Presence
          </h4>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">
            Follow my journey, see my experiments, or just reach out for a quick
            chat.
          </p>

          <ul class="grid grid-cols-1 gap-6 md:grid-cols-2">
            {
              SOCIALS.map((SOCIAL) => (
                <li class="group flex flex-col gap-1 border-l-2 border-zinc-200 pl-4 transition-colors duration-300 hover:border-cyan-500 dark:border-zinc-800">
                  <div class="flex items-center gap-2">
                    <div class="size-4 fill-zinc-500 transition-colors duration-300 group-hover:fill-cyan-500">
                      <Fragment set:html={getIcon(SOCIAL.NAME)} />
                    </div>
                    <Link
                      href={SOCIAL.HREF}
                      external
                      class="font-medium capitalize text-black dark:text-white"
                    >
                      {SOCIAL.NAME}
                    </Link>
                  </div>
                  <span class="text-xs text-zinc-500">
                    {SOCIAL.NAME === "github" &&
                      "Where I store my code and experiments."}
                    {SOCIAL.NAME === "gitlab" &&
                      "Where I backup my code and experiments."}
                    {SOCIAL.NAME === "X-Twitter" &&
                      "Thoughts, updates, and tech rants."}
                    {SOCIAL.NAME === "telegram" &&
                      "Best for a direct and quick technical chat."}
                    {SOCIAL.NAME === "instagram" &&
                      "Personal bits and visual logs."}
                    {SOCIAL.NAME === "ko-fi" &&
                      "Support my work or buy me a cup of coffee."}
                  </span>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="animate space-y-4">
          <h4 class="font-semibold text-black dark:text-white">
            Support my work
          </h4>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">
            If you find my digital garden or open-source projects useful,
            consider supporting my research and maintenance.
          </p>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div
              class="space-y-2 rounded-lg border border-black/10 p-4 dark:border-white/10"
            >
              <span
                class="text-xs font-semibold uppercase tracking-wider text-zinc-500"
                >Fiat / Traditional</span
              >
              <div class="flex items-center gap-2">
                <div class="size-4 fill-zinc-500">
                  <Fragment set:html={IconKofi} />
                </div>
                <Link
                  href="https://ko-fi.com/aadnanmt"
                  external
                  class="font-medium text-black dark:text-white"
                >
                  Ko-fi
                </Link>
              </div>
              <p class="text-xs text-zinc-500">
                Fast, 0% platform fee, supports PayPal & Cards.
              </p>
            </div>
          </div>
        </section>
      </div>
    </div>
  </Container>
</PageLayout>
