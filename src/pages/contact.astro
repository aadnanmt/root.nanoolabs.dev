---
import PageLayout from "@layouts/PageLayout.astro"
import Container from "@components/Container.astro"
import Link from "@components/Link.astro"
import TimeStatus from "@components/TimeStatus.astro"
import { SITE, SOCIALS } from "@consts"
---

<PageLayout title="Contact" description={`Get in touch with ${SITE.NAME}`}>
  <Container>
    <div class="animate space-y-10">
      <div class="animate">
        <TimeStatus />
      </div>

      <div class="space-y-12">
        <section class="animate space-y-4">
          <h4 class="font-semibold text-black dark:text-white">
            Professional Inquiries
          </h4>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">
            For collaboration, project proposals, or deep technical discussions,
            email is the most reliable way to reach me.
          </p>
          <div class="flex items-center gap-2">
            <svg
              class="size-4 fill-zinc-500"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 512 512"
              ><path
                d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4L236.8 313.6c11.4 8.5 27 8.5 38.4 0L492.8 150.4c12.1-9.1 19.2-23.3 19.2-38.4c0-26.5-21.5-48-48-48H48zM0 176V384c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V176L294.4 339.2c-22.8 17.1-54.1 17.1-76.8 0L0 176z"
              ></path></svg
            >
            <Link href={`mailto:${SITE.EMAIL}`} external>
              {SITE.EMAIL}
            </Link>
          </div>
        </section>

        <section class="animate space-y-6">
          <h4 class="font-semibold text-black dark:text-white">
            Social Presence
          </h4>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">
            Follow my journey, see my experiments, or just reach out for a quick
            chat.
          </p>

          <ul class="grid grid-cols-1 gap-6 md:grid-cols-2">
            {
              SOCIALS.map((SOCIAL) => (
                <li class="group flex flex-col gap-1 border-l-2 border-zinc-200 pl-4 transition-colors duration-300 hover:border-cyan-500 dark:border-zinc-800">
                  <Link
                    href={SOCIAL.HREF}
                    external
                    class="font-medium capitalize text-black dark:text-white"
                  >
                    {SOCIAL.NAME}
                  </Link>
                  <span class="text-xs text-zinc-500">
                    {SOCIAL.NAME === "github" &&
                      "Where I store my code and experiments."}
                    {SOCIAL.NAME === "gitlab" &&
                      "Where I backup my code and experiments."}
                    {SOCIAL.NAME === "X" &&
                      "Thoughts, updates, and tech rants."}
                    {SOCIAL.NAME === "telegram" &&
                      "Best for a direct and quick technical chat."}
                    {SOCIAL.NAME === "instagram" &&
                      "Personal bits and visual logs."}
                    {SOCIAL.NAME === "wakatime" &&
                      "Real-time coding stats and language breakdown."}
                    {SOCIAL.NAME === "ko-fi" &&
                      "Support my work or buy me a cup of coffee."}
                  </span>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="animate space-y-4">
          <h4 class="font-semibold text-black dark:text-white">
            Support my work
          </h4>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">
            If you find my digital garden or open-source projects useful,
            consider supporting my research and maintenance.
          </p>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div
              class="space-y-2 rounded-lg border border-black/10 p-4 dark:border-white/10"
            >
              <span
                class="text-xs font-semibold uppercase tracking-wider text-zinc-500"
                >Fiat / Traditional</span
              >
              <div class="flex items-center gap-2">
                <Link
                  href="https://ko-fi.com/aadnanmt"
                  external
                  class="font-medium text-black dark:text-white"
                >
                  Ko-fi
                </Link>
              </div>
              <p class="text-xs text-zinc-500">
                Fast, 0% platform fee, supports PayPal & Cards.
              </p>
            </div>
            {
              /* 
            <div class="p-4 rounded-lg border border-black/10 dark:border-white/10 space-y-2">
              <span class="text-xs font-semibold uppercase tracking-wider text-zinc-500">Crypto</span>
              <div class="flex flex-col gap-1">
                <code class="text-[10px] bg-zinc-100 dark:bg-white/5 px-2 py-1 rounded truncate" title="ETH Address">
                  BTC: 
                </code>
                <code class="text-[10px] bg-zinc-100 dark:bg-white/5 px-2 py-1 rounded truncate" title="SOL Address">
                  ETH: 
                </code>
              </div>
              <p class="text-xs text-zinc-500">For the decentralized supporters.</p>
            </div>
            */
            }
          </div>
        </section>
      </div>
    </div>
  </Container>
</PageLayout>
