---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import BackToPrev from "@components/BackToPrev.astro";
import Link from "@components/Link.astro";
import { SOCIALS } from "@consts"; // Import SOCIALS

const pages = [
  { name: "Home", href: "/", desc: "The beginning of everything." },
  {
    name: "Blog",
    href: "/blog",
    desc: "My thoughts, tutorials, and technical articles.",
  },
  {
    name: "Work",
    href: "/work",
    desc: "My journey and experiences.",
  },
  {
    name: "Projects",
    href: "/projects",
    desc: "A showcase of things I've built.",
  },
  {
    name: "Now",
    href: "/now",
    desc: "What I'm focusing on at this exact moment.",
  },
  {
    name: "Credits",
    href: "/credits",
    desc: "Tools and people that made this site possible.",
  },
];
---

<PageLayout title="Explore" description="Explore all pages on this site.">
  <Container>
    <div class="space-y-10">
      <div class="animate">
        <BackToPrev href="/"> Back to home </BackToPrev>
      </div>

      <div class="animate font-semibold text-black dark:text-white">
        Explore
      </div>

      <p class="animate">
        Use the links below to navigate through the different sections of this
        site.
      </p>

      <ul class="flex flex-col space-y-8">
        {
          pages.map((page) => (
            <li class="animate">
              <div class="space-y-1">
                <Link
                  href={page.href}
                  class="font-semibold text-black dark:text-white"
                >
                  {page.name}
                </Link>
                <div class="text-sm opacity-75">{page.desc}</div>
              </div>
            </li>
          ))
        }
      </ul>

      <div class="animate border-t border-black/10 pt-10 dark:border-white/10">
        <div class="mb-4 font-semibold text-black dark:text-white">Socials</div>
        <ul class="flex flex-wrap gap-2">
          {
            SOCIALS.map(
              (
                social, // Use SOCIALS from @consts
              ) => (
                <li class="flex gap-x-2 text-nowrap">
                  <Link href={social.HREF} external aria-label={social.NAME}>
                    {social.NAME}
                  </Link>
                  {"/"}
                </li>
              ),
            )
          }
        </ul>
      </div>
    </div>
  </Container>
</PageLayout>
