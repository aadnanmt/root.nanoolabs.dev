---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import Container from "@components/Container.astro"
import ArrowCard from "@components/ArrowCard.astro"
import { IconCommands } from "@lib/iconSystem"
import BackToPrev from "@components/BackToPrev.astro"

const commands = (await getCollection("commands")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
)

const title = "Linux Commands"
const description = "A collection of Linux commands and hacks that I use."
---

<PageLayout title={title} description={description}>
  <Container>
    <div class="space-y-10">
      <BackToPrev href="/explore"> Back to explore </BackToPrev>
      <div
        class="animate flex items-center gap-2 font-semibold text-black dark:text-white"
      >
        <div class="size-5 fill-current">
          <Fragment set:html={IconCommands} />
        </div>
        Commands
      </div>
      <div class="space-y-4">
        <p class="animate">
          This is my personal wiki for Linux commands. No fluff, just pure
          functionality and specific use cases that i've tested myself.
        </p>
      </div>
      <div class="space-y-4">
        <ul class="flex flex-col gap-4">
          {
            commands.map((command) => (
              <li class="animate">
                <ArrowCard entry={command} />
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Container>
</PageLayout>
