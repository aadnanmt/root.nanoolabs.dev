---
import { getEntry } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import Container from "@components/Container.astro"
import BackToPrev from "@components/BackToPrev.astro"
import FormattedDate from "@components/FormattedDate.astro"
import { IconUses } from "@lib/iconSystem"

const entry = await getEntry("uses", "main")

if (!entry) {
  return Astro.redirect("/404")
}

const { Content } = await entry.render()
---

<PageLayout title={entry.data.title} description={entry.data.description}>
  <Container>
    <div class="space-y-10">
      <BackToPrev href="/explore"> Back to explore </BackToPrev>

      <div class="space-y-2">
        <div
          class="animate flex items-center gap-2 font-semibold text-black dark:text-white"
        >
          <div class="size-5 fill-current">
            <Fragment set:html={IconUses} />
          </div>
          {entry.data.title}
        </div>
        <div class="animate text-sm opacity-60">
          Last updated: <FormattedDate date={entry.data.lastUpdated} />
        </div>
      </div>

      <article class="animate prose prose-neutral max-w-none dark:prose-invert">
        <Content />
      </article>
    </div>
  </Container>
</PageLayout>
