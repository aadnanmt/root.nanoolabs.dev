---
import PageLayout from "@layouts/PageLayout.astro"
import Container from "@components/Container.astro"
import BackToPrev from "@components/BackToPrev.astro"
import { IconStats } from "@lib/iconSystem"
import Link from "@components/Link.astro"
import NowPlaying from "@components/NowPlaying.astro"

// Fetch data
const response = await fetch(
  "https://raw.githubusercontent.com/aadnanmt/readmeSync/main/stats.json",
)
const stats = await response.json()
const { totalCommits, languages, updatedAt } = stats

interface Language {
  name: string
  percentage: string
}

function PacmanBar(percentage: number) {
  const totalWidth = 20
  const progress = Math.round((percentage / 100) * totalWidth)
  const hash = "█".repeat(progress)
  const dash = "░".repeat(totalWidth - progress)
  return `[${hash}${dash}] ${percentage.toFixed(1)}%`
}

const title = "Statistics"
const description = "My activity and language distribution."
---

<PageLayout title={title} description={description}>
  <Container>
    <div class="space-y-10">
      <BackToPrev href="/explore"> Back to explore </BackToPrev>

      <div
        class="animate flex items-center gap-2 font-semibold text-black dark:text-white"
      >
        <div class="size-5 fill-current">
          <Fragment set:html={IconStats} />
        </div>
        Statistics
      </div>

      <p class="animate">
        It represents my programming activity and language preferences over the
        past year.
      </p>

      <div class="animate space-y-12">
        <!-- Activity Section -->
        <section class="space-y-4">
          <h2
            class="border-b border-black/5 pb-2 font-semibold text-black dark:border-white/5 dark:text-white"
          >
            Global Activity
          </h2>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div class="space-y-1">
              <div class="text-sm tracking-wider opacity-50">Total Commits</div>
              <div class="font-mono text-2xl font-bold text-cyan-500">
                {totalCommits}
              </div>
            </div>
            <div class="space-y-1">
              <div class="text-sm tracking-wider opacity-50">Last Sync</div>
              <div class="font-mono text-sm italic">
                {new Date(updatedAt).toLocaleDateString("en-GB")}
              </div>
            </div>
          </div>
        </section>

        <!-- Languages Section -->
        <section class="space-y-6">
          <h2
            class="border-b border-black/5 pb-2 font-semibold text-black dark:border-white/5 dark:text-white"
          >
            Language Distribution
          </h2>
          <div class="space-y-8">
            {
              languages.map((lang: Language) => (
                <div class="space-y-2">
                  <div class="flex items-center justify-between">
                    <h3 class="text-sm font-medium text-black dark:text-white">
                      {lang.name}
                    </h3>
                  </div>
                  <div class="whitespace-pre font-mono text-sm text-cyan-500 sm:text-base">
                    {PacmanBar(parseFloat(lang.percentage))}
                  </div>
                </div>
              ))
            }
          </div>
        </section>
      </div>

      <div class="animate pt-10">
        <NowPlaying />
      </div>

      <div
        class="animate mt-12 border-t border-black/10 pt-8 text-xs italic opacity-50 dark:border-white/10"
      >
        Source: <Link href="https://github.com/aadnanmt/readmeSync" external
          >github.com/aadnanmt/readmeSync</Link
        >
      </div>
    </div>
  </Container>
</PageLayout>
