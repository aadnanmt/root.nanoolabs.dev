---
import Container from "@components/Container.astro"
import { SITE } from "@consts"
import BackToTop from "@components/BackToTop.astro"
import Link from "@components/Link.astro"
import RingNav from "@components/RingNav.astro"
import pkg from "../../package.json"

const version = `v${pkg.version}`
const currentYear = new Date().getFullYear()
const gitHash = import.meta.env.GIT_HASH
const repoUrl = "https://github.com/aadnanmt/root.nanoolabs.dev"
---

<footer class="animate">
  <Container>
    <div class="relative">
      <div class="absolute -top-20 right-0">
        <BackToTop />
      </div>
    </div>

    <div class="mb-12 flex justify-center">
      <RingNav />
    </div>

    <div
      class="mb-8 flex select-none justify-center opacity-20 transition-opacity hover:opacity-50"
    >
      <pre
        class="font-mono text-xs leading-none">
█▄ █ ▄▀█ █▄ █ █▀█ █▀█
█ ▀█ █▀█ █ ▀█ █▄█ █▄█
      </pre>
    </div>

    <div
      class="flex flex-col items-center justify-between gap-y-4 text-sm md:flex-row"
    >
      <div class="flex flex-wrap items-center gap-2">
        &copy; {currentYear}
        {SITE.NAME}
        <span class="opacity-50">|</span>
        <span class="flex items-center gap-1 font-mono opacity-50">
          <Link
            href={`${repoUrl}/blob/main/package.json`}
            external
            underline={false}
            class="transition-colors hover:text-cyan-400"
          >
            {version}
          </Link>
          {
            gitHash && gitHash !== "unknown" && (
              <>
                <span>(</span>
                <Link
                  href={`${repoUrl}/commit/${gitHash}`}
                  external
                  underline={false}
                  class="transition-colors hover:text-cyan-400"
                >
                  {gitHash}
                </Link>
                <span>)</span>
              </>
            )
          }
        </span>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <Link
          href="/credits"
          underline={false}
          class="transition-colors hover:text-cyan-400"
        >
          Credits
        </Link>
        <span class="opacity-50">|</span>
        <Link
          href={`${repoUrl}/blob/main/CHANGELOG.md`}
          external
          underline={false}
          class="transition-colors hover:text-cyan-400"
        >
          Changelog
        </Link>
        <span class="opacity-50">|</span>
        <Link
          href="https://creativecommons.org/licenses/by/4.0/"
          external
          underline={false}
          class="transition-colors hover:text-cyan-400"
        >
          CC BY 4.0
        </Link>
      </div>
    </div>
  </Container>
</footer>
