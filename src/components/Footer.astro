---
import Container from "@components/Container.astro"
import { SITE } from "@consts"
import BackToTop from "@components/BackToTop.astro"
import Link from "@components/Link.astro"
import pkg from "../../package.json"

const version = `v${pkg.version}`
const currentYear = new Date().getFullYear()
---

<footer class="animate">
  <Container>
    <div class="relative">
      <div class="absolute -top-20 right-0">
        <BackToTop />
      </div>
    </div>
    <div
      class="flex flex-col items-center justify-between gap-y-4 text-sm md:flex-row"
    >
      <div class="flex flex-wrap items-center gap-2">
        &copy; {currentYear}
        {SITE.NAME}
        <span class="opacity-50">|</span>
        <span class="font-mono opacity-50">
          {version} ({import.meta.env.GIT_HASH})
        </span>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <Link
          href="/credits"
          underline={false}
          class="transition-colors hover:text-cyan-400"
        >
          Credits
        </Link>
        <span class="opacity-50">|</span>
        <Link
          href="https://creativecommons.org/licenses/by/4.0/"
          external
          underline={false}
          class="transition-colors hover:text-cyan-400"
        >
          CC BY 4.0
        </Link>
      </div>
    </div>
  </Container>
</footer>
